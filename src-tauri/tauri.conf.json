{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "ScreenExtend",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": true,
        "scope": [
          {
            "name": "nefconc",
            "sidecar": true,
            "args": true
          },
          {
            "name": "certutil",
            "cmd": "certutil",
            "args": true
          },
          {
            "name": "screenextend",
            "cmd": "screenextend",
            "args": true
          },
          {
            "name": "netsh",
            "cmd": "netsh",
            "args": true
          }
        ]
      },
      "clipboard": {
        "all": false,
        "writeText": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.screen.extend",
      "publisher": "Sarvesh Madullapalli",
      "copyright": "© 2024 Sarvesh Madullapalli All Rights Reserved",
      "category": "Utility",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "externalBin": [
        "nefconc"
      ],
      "resources": [
        "VirtualDisplayDriver.dll",
        "VirtualDisplayDriver.cat",
        "VirtualDisplayDriver.inf",
        "ScreenExtend.cer"
      ]
    },
    "cli": {
      "subcommands": {
        "hostednetwork": {
          "args": [
            {
              "name": "ssid",
              "index": 1,
              "takesValue": true
            },
            {
              "name": "password",
              "index": 2,
              "takesValue": true
            }
          ]
        },
        "installdrivers": {
          "args": []
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": []
  }
}
