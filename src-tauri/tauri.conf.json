{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Screen Extend",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "clipboard": {
        "all": false,
        "writeText": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.screen.extend",
      "publisher": "Sarvesh Madullapalli",
      "copyright": "© 2024 Sarvesh Madullapalli All Rights Reserved",
      "category": "Utility",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    },
    "cli": {
      "subcommands": {
        "hostednetwork": {
          "args": [
            {
              "name": "ssid",
              "index": 1,
              "takesValue": true
            },
            {
              "name": "password",
              "index": 2,
              "takesValue": true
            }
          ]
        },
        "installdrivers": {
          "args": []
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": []
  }
}
